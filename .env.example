# Local development environment for code829-backend
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` (or paste into your shell / Infisical) and fill in
# values. Backend reads every key below directly — there is no URL form for
# the database or Redis; both connection strings are composed at boot from
# the listed components.
#
# Production / Render values live in render.example.env, NOT here.
# Workflow secrets live in .github/workflow-secrets.example.env, NOT here.


# ─── Runtime ─────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
PORT=8000
FRONTEND_URL=http://localhost:5173
FRONTEND_URL_ADMIN=http://localhost:5174
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176


# ─── Postgres (Supabase CLI on :54322 by default) ────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=54322
DB_USER=postgres
DB_NAME=postgres
DB_PASSWORD=postgres
DATABASE_SSL_MODE=Disable


# ─── Redis (docker-compose) ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=
REDIS_PASSWORD=ep_dev_redis_password
REDIS_TLS=false


# ─── Auth + signing ──────────────────────────────────────────────────────────
# 32+ bytes. Generate: openssl rand -hex 32
JWT_SECRET=


# ─── Stripe ──────────────────────────────────────────────────────────────────
# Test keys (sk_test_*, pk_test_*) for local — live keys blocked outside Production.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=


# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Optional in dev — absent → MockEmailService is used.
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=


# ─── Storage ─────────────────────────────────────────────────────────────────
# Optional in dev — absent → LocalFileStorageService is used.
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_ENDPOINT_URL=
CDN_BASE_URL=


# ─── Observability (optional — leave blank to disable transports) ────────────
SENTRY_DSN=
SENTRY_RELEASE=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=
