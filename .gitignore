# Log files — runtime output only. Source directories named Logs/ stay tracked.
/logs/
api/logs/
*.log
*.log.*

# NuGet
*.nupkg
*.snupkg
**/packages/
.nuget/
# Restore packages with 'dotnet restore' or 'nuget restore'
# Packages folder is ignored, but lock files are tracked for reproducible builds.

